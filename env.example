# Copy this file to client/.env (never commit real secrets). Vite exposes only VITE_* keys to the browser.
#
# InsForge Configuration
# Get these values from your InsForge dashboard: https://insforge.dev

# Your InsForge backend URL (required for authentication)
VITE_INSFORGE_BASE_URL=https://your-app.region.insforge.app

# Anonymous key (optional, only needed for database/storage operations)
VITE_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# --- Netlify / CI ---
# Set the same VITE_* variables in the host dashboard (Build environment variables).
# Redeploy after changing them — Vite inlines them at build time, not runtime.
# In InsForge, add your production origin (e.g. https://syncboards.netlify.app) to OAuth redirect allowlist.

